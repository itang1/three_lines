# Supabase (Settings > API in your Supabase project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Bible text providers
# ESV API key from https://api.esv.org (used for ESV passages)
ESV_API_KEY=
# API.Bible key from https://scripture.api.bible (used for non-ESV translations)
BIBLE_API_KEY=

# Resend (contact form emails) from https://resend.com
RESEND_API_KEY=

# Public site URL, used for metadata, sitemap, and robots.
# Optional locally; defaults to https://threelines.app if unset.
NEXT_PUBLIC_SITE_URL=
