# Supabase (Settings > API in your Supabase project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Bible text providers
# ESV API key from https://api.esv.org (used for ESV passages)
ESV_API_KEY=
# API.Bible key from https://scripture.api.bible (used for non-ESV translations)
BIBLE_API_KEY=

# Resend (contact form emails) from https://resend.com
RESEND_API_KEY=
# Optional. Verified sender for reply emails, e.g. "Three Lines <hi@yourdomain.com>".
# Falls back to the resend.dev sandbox sender (only delivers to the account owner).
RESEND_FROM=

# Public site URL, used for metadata, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=

# Google service account JSON key from console.cloud.google.com (used for Sheets logging)
GOOGLE_SERVICE_ACCOUNT_JSON=
# Optional. Overrides the spreadsheet that feedback/visits are logged to.
# Falls back to the built-in default sheet id.
GOOGLE_SHEETS_ID=
